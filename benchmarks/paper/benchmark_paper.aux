\@writefile{toc}{\contentsline {section}{\numberline {1}The Question}{1}{section.1}\protected@file@percent }
\@writefile{toc}{\contentsline {section}{\numberline {2}How They Work (Architecture)}{1}{section.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {What's actually running.} Native (left) keeps everything in one Python process. JSII (right) splits work across three OS processes — your Python code talks to a Node.js JSII runtime over stdin/stdout pipes, which forks a program process that runs the TypeScript agent logic. Tool callbacks (red dashed arrow) go back across the bridge.}}{2}{figure.caption.1}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:arch}{{1}{2}{\textbf {What's actually running.} Native (left) keeps everything in one Python process. JSII (right) splits work across three OS processes — your Python code talks to a Node.js JSII runtime over stdin/stdout pipes, which forks a program process that runs the TypeScript agent logic. Tool callbacks (red dashed arrow) go back across the bridge}{figure.caption.1}{}}
\@writefile{toc}{\contentsline {section}{\numberline {3}The Benchmark}{2}{section.3}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces \textbf  {Benchmark setup.} Same prompt, same tool, same model, same machine. The ``50 tool calls'' workload stresses the tool callback path — the part most affected by the JSII bridge overhead.}}{2}{table.caption.2}\protected@file@percent }
\@writefile{toc}{\contentsline {section}{\numberline {4}Results: The Numbers}{2}{section.4}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {4.1}Timing — How Fast?}{3}{subsection.4.1}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \textbf  {Timing comparison.} Import is nearly identical. Construction is 25$\times $ faster with JSII (Node.js is already running). Invoke overhead is 15\% — but read on before drawing conclusions.}}{3}{figure.caption.3}\protected@file@percent }
\newlabel{fig:timing}{{2}{3}{\textbf {Timing comparison.} Import is nearly identical. Construction is 25$\times $ faster with JSII (Node.js is already running). Invoke overhead is 15\% — but read on before drawing conclusions}{figure.caption.3}{}}
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces \textbf  {Timing details.} JSII construction is near-instant because Node.js is already running from import time. The invoke delta is within Bedrock variance.}}{3}{table.caption.4}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {4.2}Memory — The Honest Picture}{3}{subsection.4.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {The real memory picture.} Native is one bar. JSII is three stacked bars — and the total is 2$\times $ larger. The Node.js overhead (122\,MB) is a fixed cost that doesn't grow with conversation length.}}{3}{figure.caption.5}\protected@file@percent }
\newlabel{fig:memory}{{3}{3}{\textbf {The real memory picture.} Native is one bar. JSII is three stacked bars — and the total is 2$\times $ larger. The Node.js overhead (122\,MB) is a fixed cost that doesn't grow with conversation length}{figure.caption.5}{}}
\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces \textbf  {Where the memory goes.} JSII's Python process is lighter because it doesn't load boto3, botocore, urllib3, or ssl — those live in Node.js instead. But two V8 engines cost $\sim $80\,MB of baseline.}}{4}{table.caption.6}\protected@file@percent }
\newlabel{tab:memory}{{3}{4}{\textbf {Where the memory goes.} JSII's Python process is lighter because it doesn't load boto3, botocore, urllib3, or ssl — those live in Node.js instead. But two V8 engines cost $\sim $80\,MB of baseline}{table.caption.6}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.3}CPU — Where the Work Actually Happens}{4}{subsection.4.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {Python-side CPU usage.} JSII uses 10$\times $ less CPU in the Python process because all the real work (stream parsing, botocore deserialization, asyncio scheduling) happens in Node.js V8 instead.}}{4}{figure.caption.7}\protected@file@percent }
\newlabel{fig:cpu}{{4}{4}{\textbf {Python-side CPU usage.} JSII uses 10$\times $ less CPU in the Python process because all the real work (stream parsing, botocore deserialization, asyncio scheduling) happens in Node.js V8 instead}{figure.caption.7}{}}
\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces \textbf  {CPU efficiency.} Both SDKs are I/O-bound (waiting on Bedrock), but Native does meaningful Python work between waits. JSII's Python process is essentially asleep.}}{4}{table.caption.8}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {4.4}Under the Hood — What Python Is Actually Doing}{4}{subsection.4.4}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces \textbf  {Python function calls.} Native makes 182k Python function calls. JSII makes 13.8k — a 13$\times $ reduction. Zero botocore, zero asyncio — all of that runs in Node.js.}}{5}{figure.caption.9}\protected@file@percent }
\newlabel{fig:calls}{{5}{5}{\textbf {Python function calls.} Native makes 182k Python function calls. JSII makes 13.8k — a 13$\times $ reduction. Zero botocore, zero asyncio — all of that runs in Node.js}{figure.caption.9}{}}
\@writefile{lot}{\contentsline {table}{\numberline {5}{\ignorespaces \textbf  {Where time is spent.} Native: SSL reads + botocore + asyncio. JSII: 99.6\% of time is a single \texttt  {readline()} call, waiting for Node.js to finish. Python literally does nothing else.}}{5}{table.caption.10}\protected@file@percent }
\newlabel{tab:hotspots}{{5}{5}{\textbf {Where time is spent.} Native: SSL reads + botocore + asyncio. JSII: 99.6\% of time is a single \texttt {readline()} call, waiting for Node.js to finish. Python literally does nothing else}{table.caption.10}{}}
\@writefile{toc}{\contentsline {section}{\numberline {5}The Worker Threads Optimization}{5}{section.5}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces \textbf  {How we bridge sync and async.} The main thread blocks on \texttt  {Atomics.wait()}. The Worker thread runs the async AWS SDK call freely. When done, it writes the result into shared memory and notifies. No files, no forks, no disk I/O.}}{5}{figure.caption.11}\protected@file@percent }
\newlabel{fig:worker}{{6}{5}{\textbf {How we bridge sync and async.} The main thread blocks on \texttt {Atomics.wait()}. The Worker thread runs the async AWS SDK call freely. When done, it writes the result into shared memory and notifies. No files, no forks, no disk I/O}{figure.caption.11}{}}
\@writefile{lot}{\contentsline {table}{\numberline {6}{\ignorespaces \textbf  {Per-call overhead eliminated.} Every model call (Bedrock, Anthropic, OpenAI, Ollama, Gemini) used to fork a child process and write temp files. Now it's all in-process via Worker Threads.}}{6}{table.caption.12}\protected@file@percent }
\newlabel{tab:worker}{{6}{6}{\textbf {Per-call overhead eliminated.} Every model call (Bedrock, Anthropic, OpenAI, Ollama, Gemini) used to fork a child process and write temp files. Now it's all in-process via Worker Threads}{table.caption.12}{}}
\@writefile{toc}{\contentsline {section}{\numberline {6}The Scorecard}{6}{section.6}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {7}{\ignorespaces \textbf  {The full picture.} \colorbox {nativelt}{\textsf  {Green}} = JSII advantage. \colorbox {jsiilt}{\textsf  {Purple}} = Native advantage. \colorbox {warnlt}{\textsf  {Red}} = significant Native advantage. JSII wins on speed, CPU efficiency, and polyglot; Native wins on total memory.}}{6}{table.caption.13}\protected@file@percent }
\newlabel{tab:scorecard}{{7}{6}{\textbf {The full picture.} \colorbox {nativelt}{\textsf {Green}} = JSII advantage. \colorbox {jsiilt}{\textsf {Purple}} = Native advantage. \colorbox {warnlt}{\textsf {Red}} = significant Native advantage. JSII wins on speed, CPU efficiency, and polyglot; Native wins on total memory}{table.caption.13}{}}
\@writefile{toc}{\contentsline {section}{\numberline {7}When Should You Use Which?}{7}{section.7}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces \textbf  {Decision guide.} Both are production-ready. The choice depends on your deployment constraints.}}{7}{figure.caption.14}\protected@file@percent }
\newlabel{fig:decision}{{7}{7}{\textbf {Decision guide.} Both are production-ready. The choice depends on your deployment constraints}{figure.caption.14}{}}
\@writefile{toc}{\contentsline {section}{\numberline {8}Caveats and Future Work}{7}{section.8}\protected@file@percent }
