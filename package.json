{
  "name": "@strands-agents/jsii",
  "version": "0.1.0",
  "description": "Strands Agents SDK - Multi-language bindings via jsii (Python, Java, C#, Go)",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "scripts": {
    "build": "jsii",
    "build:watch": "jsii --watch",
    "package": "jsii-pacmak",
    "package:python": "jsii-pacmak --targets python",
    "package:java": "jsii-pacmak --targets java",
    "package:dotnet": "jsii-pacmak --targets dotnet",
    "package:go": "jsii-pacmak --targets go",
    "package:all": "jsii-pacmak",
    "test": "jest",
    "clean": "rm -rf lib dist .jsii tsconfig.json node_modules"
  },
  "stability": "experimental",
  "author": {
    "name": "Strands Agents",
    "url": "https://github.com/strands-agents"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/cagataycali/strands-jsii-test.git"
  },
  "jsii": {
    "outdir": "dist",
    "versionFormat": "full",
    "tsc": {
      "outDir": "lib",
      "rootDir": "src"
    },
    "targets": {
      "python": {
        "distName": "strands-agents-jsii",
        "module": "strands_agents_jsii"
      },
      "java": {
        "package": "io.github.strands.agents.jsii",
        "maven": {
          "groupId": "io.github.strands-agents",
          "artifactId": "strands-agents-jsii"
        }
      },
      "dotnet": {
        "namespace": "Strands.Agents.Jsii",
        "packageId": "Strands.Agents.Jsii"
      },
      "go": {
        "moduleName": "github.com/strands-agents/strands-agents-go"
      }
    }
  },
  "bundledDependencies": [
    "@aws-sdk/client-bedrock-runtime"
  ],
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.943.0"
  },
  "devDependencies": {
    "jsii": "~5.9.0",
    "jsii-pacmak": "^1.106.0",
    "jsii-rosetta": "~5.9.0",
    "jest": "^29.0.0",
    "@types/jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "~5.7.0"
  },
  "peerDependencies": {},
  "keywords": [
    "strands",
    "agents",
    "ai",
    "jsii",
    "multi-language",
    "python",
    "java",
    "dotnet",
    "go"
  ]
}
